---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, pubDate, tags = [] } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<!-- Blog posts are indexable (noindex defaults to false). -->
<Layout title={`${title} | Nilotpal M. Saharia`} description={description}>
  <Header />

  <article class="post">
    <div class="wrap">
      <div class="post-header reveal">
        <a class="back-link" href="/blog">← All posts</a>
        <div class="meta">
          <span>{fmt(pubDate)}</span>
        </div>
        <h1>{title}</h1>
        <p class="desc">{description}</p>
      </div>

      <div class="prose reveal">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="post-foot">
          <div class="tags">
            {tags.map((t) => <span class="tag-pill">{t}</span>)}
          </div>
          <a class="back-link" style="margin:0" href="/blog">← All posts</a>
        </div>
      )}
    </div>
  </article>

  <Footer />
</Layout>
